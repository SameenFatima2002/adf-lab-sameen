{
	"name": "ds_source_csv",
	"properties": {
		"linkedServiceName": {
			"referenceName": "ls_blob_storage",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"filename": {
				"type": "string"
			},
			"containerName": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"fileName": {
					"value": "@dataset().filename",
					"type": "Expression"
				},
				"container": {
					"value": "@dataset().containerName",
					"type": "Expression"
				}
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": [
			{
				"name": "ID",
				"type": "String"
			},
			{
				"name": "Name",
				"type": "String"
			},
			{
				"name": "Age",
				"type": "String"
			},
			{
				"name": "City",
				"type": "String"
			}
		]
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}